# Build context = AutoSubs-App/src-tauri (the Cargo workspace root).
# Keep the context tiny: Rust build output, VCS, editor and OS cruft.

# Cargo build artifacts (workspace + per-crate)
target/
**/target/

# Rust analyzer / IDE
.idea/
.vscode/
*.iml

# VCS (context starts at src-tauri, but be explicit)
.git/
.gitignore

# OS noise
.DS_Store
Thumbs.db

# The image itself / compose / docs don't belong in the build context
Dockerfile
.dockerignore

# Tauri build/runtime outputs that are irrelevant to the CLI build
gen/
*.log
